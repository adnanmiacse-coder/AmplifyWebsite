# Public environment variables for the frontend build
# Replace placeholder values in your local .env file or Vercel project settings.
VITE_API_BASE=/api
VITE_OPENROUTER_BASE=https://openrouter.ai/api/v1
VITE_GROQ_BASE=https://api.groq.com/openai/v1

# The following values are sensitive and should only be defined in your local .env or Vercel secrets.
# Do not commit actual secret keys into git.
VITE_OPENROUTER_KEYS='["sk-or-v1-yourkey1","sk-or-v1-yourkey2"]'
VITE_GROQ_KEYS='["gsk_yourkey1","gsk_yourkey2"]'
VITE_GROQ_API_KEY=your_groq_single_key
VITE_CEREBRAS_API_KEY=your_cerebras_key
